#!/usr/bin/env bash
# commit-msg hook: forbid attribution trailers in commit messages.
# Forbidden: Co-Authored-By trailers, Generated with/by, claude.ai, anthropic, robot emoji (🤖)
# Reference an issue with the GitHub number, e.g. [#445]; [agent:NAME] / [area] prefixes are allowed.
# Rules live in the repo (FUCK_CLAUDE_FUCK_PAPERCLIP.md + CLAUDE.md), not in any external tracker.

set -euo pipefail

COMMIT_MSG=$(cat "$1")

reject() {
    local reason="$1"
    echo "" >&2
    echo "  COMMIT REJECTED: forbidden content in commit message" >&2
    echo "  Reason: $reason" >&2
    echo "" >&2
    echo "  Commit policy:" >&2
    echo "    Format:   [#<issue>] [area] <imperative>   (e.g. [#445] [impl] add ...)" >&2
    echo "    Allowed:  [#<issue>] GitHub refs, [agent:NAME] / [area] prefixes" >&2
    echo "    Forbidden: Co-Authored-By (any variant), Generated with/by," >&2
    echo "               claude.ai, anthropic, robot emoji (🤖)" >&2
    echo "" >&2
    echo "  Your commit message (first 10 lines):" >&2
    echo "  ---" >&2
    echo "$COMMIT_MSG" | head -10 | sed 's/^/  /' >&2
    echo "  ---" >&2
    echo "" >&2
    exit 1
}

# Check for robot emoji (fixed-string, not regex)
if echo "$COMMIT_MSG" | grep -qF "🤖"; then
    reject "robot emoji (🤖) in commit message"
fi

# Case-insensitive pattern checks — stop at first match
if echo "$COMMIT_MSG" | grep -qiE "Co-Authored-By:"; then
    reject "Co-Authored-By trailer"
fi
if echo "$COMMIT_MSG" | grep -qiE "Generated (with|by)"; then
    reject "Generated with/by phrase"
fi
if echo "$COMMIT_MSG" | grep -qiE "claude\.ai"; then
    reject "claude.ai attribution"
fi
if echo "$COMMIT_MSG" | grep -qiE "anthropic"; then
    reject "Anthropic attribution"
fi

exit 0
