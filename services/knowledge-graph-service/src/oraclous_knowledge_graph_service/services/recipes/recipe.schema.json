{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oraclous.dev/schemas/recipe/0.2",
  "title": "Oraclous Ingestion Recipe",
  "$comment": "Formalizes knowledge-graph-builder/docs/recipe-spec.md (TASK-220, STORY-034, ADR-022). A recipe is data, not code.",
  "type": "object",
  "required": ["recipe_format_version", "id", "version", "status", "concern", "applies_to", "mappings"],
  "additionalProperties": false,
  "properties": {
    "recipe_format_version": { "const": "0.2" },
    "id": { "type": "string", "pattern": "^rcp_[A-Za-z0-9._-]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "promoted"] },
    "concern": { "type": "string", "minLength": 1 },
    "applies_to": {
      "type": "object",
      "required": ["source_type", "shape_signature"],
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "enum": ["relational", "csv", "json", "text", "code", "timeseries", "event_log", "geospatial", "graph"]
        },
        "shape_signature": { "type": "string", "minLength": 1 }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provenance": { "enum": ["EXTRACTED", "INFERRED"] },
        "materialize_fine_grain": { "type": "boolean" }
      }
    },
    "authoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authored_by": { "type": "string" },
        "created": { "type": "string", "format": "date" },
        "sample_basis": { "type": "string" },
        "design_notes_ref": { "type": "string" }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping" }
    }
  },
  "$defs": {
    "safe_identifier": {
      "type": "string",
      "pattern": "^(?!__)[A-Za-z_][A-Za-z0-9_]*$",
      "$comment": "Cypher-safe identifier; the (?!__) guard rejects the ADR-015 reserved __wrapped__ namespace."
    },
    "transform": {
      "type": "string",
      "minLength": 1,
      "$comment": "Name of a deterministic value transform (domain/recipes/transforms.py: host|lower|strip_www) applied to the read value BEFORE it is used. The transform name is validated against the registry at recipe-validation time (unknown → RecipeValidationError)."
    },
    "match": {
      "type": "object",
      "required": ["unit_kind"],
      "additionalProperties": false,
      "properties": {
        "unit_kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "identity": {
      "type": "object",
      "required": ["scheme", "from"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "deterministic" },
        "from": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "normalize": {
          "type": "array",
          "items": { "enum": ["casefold", "trim", "collapse_whitespace"] }
        },
        "transform": {
          "$ref": "#/$defs/transform",
          "$comment": "One transform applied to EACH read identity field value (after normalize)."
        }
      }
    },
    "property_projection": {
      "type": "object",
      "required": ["name", "value_from"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/safe_identifier" },
        "value_from": { "type": "string", "minLength": 1 },
        "transform": { "$ref": "#/$defs/transform" }
      }
    },
    "mapping": {
      "$comment": "A mapping rule is a discriminated union on project_to; exactly one branch matches.",
      "oneOf": [
        { "$ref": "#/$defs/rule_node" },
        { "$ref": "#/$defs/rule_edge" },
        { "$ref": "#/$defs/rule_property" },
        { "$ref": "#/$defs/rule_skip" },
        { "$ref": "#/$defs/rule_text_extraction" }
      ]
    },
    "rule_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "project_to", "label", "identity"],
      "$comment": "A node rule projects ONE node per matched unit. When `from_each` is present it instead FANS OUT a list-valued field into one node per element (identity = the element value); a scalar value is treated as a 1-element list, an empty/missing field projects 0 nodes (skip + warn). `edge_to_each` pairs a fan-out node with an edge from the record's primary node to each element node.",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "match": { "$ref": "#/$defs/match" },
        "project_to": { "const": "node" },
        "label": { "$ref": "#/$defs/safe_identifier" },
        "identity": { "$ref": "#/$defs/identity" },
        "materialize": { "type": "boolean" },
        "properties": { "type": "array", "items": { "$ref": "#/$defs/property_projection" } },
        "provenance": { "enum": ["EXTRACTED", "INFERRED"] },
        "from_each": {
          "type": "string",
          "minLength": 1,
          "$comment": "A field:/column: ref to a LIST field on the matched record. Each element becomes one node whose identity is the element value (passed through the rule's identity.normalize + identity.transform); MERGE collapses equal elements across records to one shared node. With from_each, identity.from is ignored — the element value is the identity."
        },
        "edge_to_each": {
          "type": "object",
          "required": ["type", "from_node_rule"],
          "additionalProperties": false,
          "$comment": "Only valid alongside `from_each`. Projects an edge (record's primary node)-[type]->(each element node).",
          "properties": {
            "type": { "$ref": "#/$defs/safe_identifier" },
            "from_node_rule": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "rule_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "project_to", "type", "from", "to"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "match": { "$ref": "#/$defs/match" },
        "project_to": { "const": "edge" },
        "type": { "$ref": "#/$defs/safe_identifier" },
        "from": {
          "type": "object",
          "required": ["node_rule"],
          "additionalProperties": false,
          "properties": { "node_rule": { "type": "string", "minLength": 1 } }
        },
        "to": {
          "type": "object",
          "required": ["node_rule", "resolve_by"],
          "additionalProperties": false,
          "properties": {
            "node_rule": { "type": "string", "minLength": 1 },
            "resolve_by": { "enum": ["foreign_key", "fk_target", "identity", "self"] },
            "from_field": {
              "type": "string",
              "minLength": 1,
              "$comment": "Required for resolve_by:foreign_key — a field:/column: ref on the SOURCE record holding the FK value(s) (scalar OR list). Each value becomes the target node_rule's identity, hashed with the engine's deterministic id; the edge MERGEs to that id, MERGE-ing a stub target if absent (cross-job/cross-file)."
            }
          }
        },
        "properties": { "type": "array", "items": { "$ref": "#/$defs/property_projection" } },
        "provenance": { "enum": ["EXTRACTED", "INFERRED"] }
      }
    },
    "rule_property": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "project_to", "on", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "match": { "$ref": "#/$defs/match" },
        "project_to": { "const": "property" },
        "on": { "type": "string", "minLength": 1 },
        "name": { "$ref": "#/$defs/safe_identifier" },
        "value_from": { "type": "string", "minLength": 1 },
        "transform": { "$ref": "#/$defs/transform" }
      }
    },
    "rule_skip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "project_to", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "match": { "$ref": "#/$defs/match" },
        "project_to": { "const": "skip" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "rule_text_extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "project_to", "primitive", "link_to", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "match": { "$ref": "#/$defs/match" },
        "project_to": { "const": "text_extraction" },
        "primitive": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "link_to": {
          "type": "object",
          "required": ["node_rule", "edge_type"],
          "additionalProperties": false,
          "properties": {
            "node_rule": { "type": "string", "minLength": 1 },
            "edge_type": { "$ref": "#/$defs/safe_identifier" }
          }
        },
        "provenance": { "const": "INFERRED" }
      }
    }
  }
}
